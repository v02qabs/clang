Okay, let's create a Gemini TUI (Text User Interface) app using Textual that allows you to chat with Gemini and save the AI's responses to a file.

**Features:**

1.  **Chat with Gemini:** Send prompts and receive responses.
2.  **Display History:** See your prompts and Gemini's replies in a scrollable log.
3.  **Save Last Response:** Press `Ctrl+S` to save the last Gemini response to a file.
4.  **Quit:** Press `Ctrl+Q` to exit the app.

---

### Prerequisites

Before you start, make sure you have:

1.  **Python 3.7+**
2.  **Google API Key for Gemini:** Get one from the [Google AI Studio](https://makersuite.google.com/text/create) (ensure you enable the Gemini API for your project).
3.  **Install necessary libraries:**

    ```bash
    pip install textual google-generativeai
    ```

---

### Step 1: Set up your API Key

It's best practice not to hardcode your API key. Set it as an environment variable:

**Linux/macOS:**

```bash
export GOOGLE_API_KEY='YOUR_API_KEY_HERE'
```

**Windows (Command Prompt):**

```cmd
set GOOGLE_API_KEY='YOUR_API_KEY_HERE'
```

**Windows (PowerShell):**

```powershell
$env:GOOGLE_API_KEY='YOUR_API_KEY_HERE'
```

Replace `'YOUR_API_KEY_HERE'` with your actual API key.

---

### Step 2: Create the TUI App (`gemini_tui.py`)

```python
import os
import google.generativeai as genai
from datetime import datetime

from textual.app import App, ComposeResult
from textual.containers import Container
from textual.widgets import Header, Footer, Input, Button, RichLog
from textual.binding import Binding
from textual.reactive import reactive

class GeminiTUI(App):
    """A Textual app to chat with Google Gemini and save responses."""

    CSS = """
    Screen {
        background: #1e1e1e;
    }

    Header {
        dock: top;
        background: #3a0050; /* Dark purple */
        color: white;
        text-align: center;
        height: 3;
    }

    Footer {
        dock: bottom;
        background: #3a0050; /* Dark purple */
        color: white;
        height: 2;
    }

    Container {
        layout: vertical;
        padding: 1;
    }

    #chat_log {
        height: 1fr; /* Takes up all available space */
        border: solid #5a0080; /* Lighter purple border */
        margin-bottom: 1;
        background: #282828;
    }

    #input_area {
        dock: bottom;
        layout: horizontal;
        height: 3;
    }

    #prompt_input {
        width: 1fr; /* Takes up most of the input area */
        height: 100%;
        border: solid #5a0080;
        background: #383838;
        color: white;
    }

    #send_button {
        width: 12;
        margin-left: 1;
        background: #5a0080; /* Lighter purple button */
        color: white;
        border: solid #7a00a0;
    }

    #send_button:hover {
        background: #7a00a0;
    }

    .error {
        color: red;
    }

    .info {
        color: yellow;
    }
    """

    BINDINGS = [
        Binding("ctrl+s", "save_response", "Save Last Response", show=True, key_display="Ctrl+S"),
        Binding("ctrl+q", "quit", "Quit", show=True, key_display="Ctrl+Q"),
    ]

    # Reactive variable to store the last AI response
    last_ai_response: reactive[str | None] = reactive(None)

    def __init__(self, *args, **kwargs):
        super().__init__(*args, **kwargs)
        self.model = None
        self._initialize_gemini()

    def _initialize_gemini(self):
        """Initializes the Gemini model."""
        api_key = os.getenv("GOOGLE_API_KEY")
        if not api_key:
            self.query_one(RichLog).write("[bold red]ERROR:[/bold red] GOOGLE_API_KEY environment variable not set.")
            self.query_one(RichLog).write("Please set it before running the app.")
            self.exit() # Exit if API key is not found
            return

        genai.configure(api_key=api_key)
        try:
            self.model = genai.GenerativeModel("gemini-pro")
            # Optionally test a small call to ensure it works
            # self.model.generate_content("hello", safety_settings={'HARASSMENT':'block_none'})
        except Exception as e:
            self.query_one(RichLog).write(f"[bold red]ERROR connecting to Gemini:[/bold red] {e}")
            self.query_one(RichLog).write("Please check your API key and internet connection.")
            self.exit()

    def compose(self) -u003e ComposeResult:
        """Create child widgets for the app."""
        yield Header()
        yield Footer()
        with Container():
            yield RichLog(id="chat_log", wrap=True, auto_scroll=True, markup=True)
            with Container(id="input_area"):
                yield Input(placeholder="Ask Gemini...", id="prompt_input")
                yield Button("Send", id="send_button", variant="primary")

    def on_mount(self) -u003e None:
        """Called when the app is mounted."""
        self.query_one("#prompt_input", Input).focus()
        self.query_one(RichLog).write("[bold magenta]Welcome to Gemini TUI![/bold magenta]")
        self.query_one(RichLog).write("Enter your prompt below and press Enter or click Send.")
        self.query_one(RichLog).write("Press [bold yellow]Ctrl+S[/bold yellow] to save the last response.")
        self.query_one(RichLog).write("Press [bold yellow]Ctrl+Q[/bold yellow] to quit.")


    async def on_button_pressed(self, event: Button.Pressed) -u003e None:
        """Event handler for the send button."""
        if event.button.id == "send_button":
            await self._send_prompt()

    async def on_input_submitted(self, event: Input.Submitted) -u003e None:
        """Event handler for the input field when Enter is pressed."""
        if event.input.id == "prompt_input":
            await self._send_prompt()

    async def _send_prompt(self) -u003e None:
        """Sends the current prompt to Gemini and displays the response."""
        prompt_input = self.query_one("#prompt_input", Input)
        chat_log = self.query_one(RichLog)
        prompt = prompt_input.value.strip()

        if not prompt:
            chat_log.write("[info]Please enter a prompt.[/info]")
            return

        # Clear input and display user prompt
        prompt_input.value = ""
        chat_log.write(f"[bold blue]You:[/bold blue] {prompt}")
        chat_log.write("[info]Thinking...[/info]")

        try:
            # Run the blocking Gemini API call in a worker thread
            # This keeps the UI responsive while the API call is made
            worker = self.run_worker(
                lambda: self.model.generate_content(prompt),
                name="gemini_call",
                group="gemini_tasks",
                thread=True,
            )
            
            # Wait for the worker to complete and get the result
            result_wrapper = await worker.wait_for_completion()
            response = result_wrapper.result

            response_text = ""
            try:
                # Access the 'text' attribute of the GenerationResponse object
                response_text = response.text
            except Exception:
                # Handle cases where response.text might not be available (e.g., safety filters)
                if hasattr(response, 'prompt_feedback') and response.prompt_feedback.block_reason:
                    response_text = f"Blocked: {response.prompt_feedback.block_reason.name}"
                else:
                    response_text = "No text content received (possibly blocked by safety filters)."

            self.last_ai_response = response_text  # Store the last response
            chat_log.write(f"[bold green]Gemini:[/bold green] {response_text}")

        except Exception as e:
            chat_log.write(f"[bold red]Error:[/bold red] {e}")
            self.last_ai_response = None # Clear on error

        chat_log.scroll_end() # Auto-scroll to the end after response
        prompt_input.focus()

    def action_save_response(self) -u003e None:
        """Saves the last AI response to a file."""
        chat_log = self.query_one(RichLog)

        if self.last_ai_response:
            timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
            filename = f"gemini_response_{timestamp}.txt"
            try:
                with open(filename, "w", encoding="utf-8") as f:
                    f.write(self.last_ai_response)
                chat_log.write(f"[bold green]Saved to:[/bold green] {filename}")
            except IOError as e:
                chat_log.write(f"[bold red]Error saving file:[/bold red] {e}")
        else:
            chat_log.write("[info]No response to save yet.[/info]")

        chat_log.scroll_end()

    def action_quit(self) -u003e None:
        """Quits the application."""
        self.exit()


if __name__ == "__main__":
    app = GeminiTUI()
    app.run()
```

---

### How to Run

1.  Save the code above as `gemini_tui.py`.
2.  Make sure your `GOOGLE_API_KEY` environment variable is set.
3.  Open your terminal or command prompt in the directory where you saved the file.
4.  Run the app:

    ```bash
    python gemini_tui.py
    ```

